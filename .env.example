# ── Required ──────────────────────────────────────────────────────────────────
# Google Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# RapidAPI key for JSearch (job listings) — https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=your_rapidapi_key_here

# ── Required unless using MCP mode ────────────────────────────────────────────
# Tavily Search API key — https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ── Optional — MCP mode ───────────────────────────────────────────────────────
# Composio-hosted Tavily MCP endpoint (run with: python main.py --mcp)
# MCP_TAVILY_URL=https://backend.composio.dev/v3/mcp/<your-id>/mcp?user_id=<your-user-id>

# ── Optional overrides ────────────────────────────────────────────────────────
# LLM_MODEL=google_genai:gemini-2.5-flash
